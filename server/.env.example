# Required on Vercel for auth (register/login will fail without these):
MONGO_URI=
JWT_SECRET=

EMAIL_USER=
EMAIL_PASS=
# Optional: deployed Python AI service (defaults to http://localhost:8000 locally)
AI_ENGINE_URL=
# Optional: axios timeout in ms for /analyze-resume (defaults: 8000 on Vercel, 15000 locally)
AI_REQUEST_TIMEOUT_MS=
# Optional: set to 1 on Vercel to include err.message in 500 JSON while debugging Apply
EXPOSE_APPLY_ERRORS=
